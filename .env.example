# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account/downloads
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account/downloads

# Neon Database
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=
BLOB_BASE_URL=

# Resend
RESEND_API_KEY=

# ConvertKit (existing)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# App
NEXT_PUBLIC_URL=https://anywherelearning.co

# Vercel webhook signing secret (for /api/indexnow auto-ping on deploy).
# Create in Vercel dashboard: Project → Settings → Webhooks → add webhook
# with URL https://anywherelearning.co/api/indexnow and event
# deployment.succeeded. Copy the generated secret into this env var
# (Production scope).
VERCEL_WEBHOOK_SECRET=
